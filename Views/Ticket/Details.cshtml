@model TicketSistemi.Models.Ticket

@{
    ViewData["Title"] = "Destek Talebi Detayı";
}

<style>
    .chat-card {
        border-radius: 20px;
        background: var(--card-bg);
        border: var(--card-border);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }
    
    .chat-header {
        border-bottom: 1px solid var(--footer-border);
        background: rgba(99, 102, 241, 0.03);
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }

    .chat-body {
        background-color: var(--bg-color);
        border-radius: 12px;
        padding: 24px;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Chat bubble base */
    .bubble {
        max-width: 75%;
        padding: 16px 20px;
        border-radius: 20px;
        position: relative;
        line-height: 1.5;
        font-size: 0.95rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        animation: fadeIn 0.3s ease;
    }

    /* Left aligned bubble (Customer / User) */
    .bubble-left {
        align-self: flex-start;
        background-color: var(--card-bg);
        color: var(--text-color);
        border-top-left-radius: 4px;
        border: 1px solid var(--footer-border);
    }

    /* Right aligned bubble (Admin / Agent) */
    .bubble-right {
        align-self: flex-end;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #ffffff;
        border-top-right-radius: 4px;
    }

    .bubble-meta {
        font-size: 0.75rem;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .bubble-left .bubble-meta {
        color: #64748b;
    }

    .bubble-right .bubble-meta {
        color: rgba(255, 255, 255, 0.75);
    }

    .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .avatar-user {
        background-color: #e0e7ff;
        color: #4f46e5;
    }

    .avatar-agent {
        background-color: #fef3c7;
        color: #d97706;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container py-3">
    <!-- Back to Index Button -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-custom rounded-pill d-inline-flex align-items-center gap-2">
            ⬅️ Panele Geri Dön
        </a>
    </div>

    <!-- Ticket Detail Header Info Card -->
    <div class="card chat-card mb-4">
        <div class="chat-header p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge bg-primary rounded-pill">Talep #@Model.Id</span>
                    @if (Model.Status == TicketSistemi.Models.TicketStatus.Acik)
                    {
                        <span class="badge rounded-pill badge-acik px-3 py-1.5">Açık</span>
                    }
                    else if (Model.Status == TicketSistemi.Models.TicketStatus.Cozuldu)
                    {
                        <span class="badge rounded-pill badge-cozuldu px-3 py-1.5">Çözüldü</span>
                    }
                    else
                    {
                        <span class="badge rounded-pill badge-kapandi px-3 py-1.5">Kapandı</span>
                    }
                </div>
                <h3 class="fw-bold mb-1 mt-2">@Model.Title</h3>
                <p class="text-secondary mb-0 small">
                    👤 Müşteri: <strong>@Model.CustomerName</strong> | 📅 Tarih: @Model.CreatedDate.ToString("dd MMMM yyyy HH:mm")
                </p>
            </div>
            
            <div class="text-md-end">
                <span class="text-secondary d-block small mb-1">Üstlenen Temsilci</span>
                @if (!string.IsNullOrEmpty(Model.AssignedAgent))
                {
                    <span class="badge fw-semibold px-3 py-2 border rounded-pill" style="color: #4338ca; background-color: #e0e7ff; border: 1px solid #c7d2fe; font-size: 0.9rem;">
                        👤 @Model.AssignedAgent
                    </span>
                }
                else
                {
                    <span class="text-muted small">Henüz Atanmadı</span>
                }
            </div>
        </div>

        <!-- Chat Conversation Body -->
        <div class="card-body p-4">
            <div class="chat-body">
                <!-- User Question Bubble (Always Left) -->
                <div class="bubble bubble-left">
                    <div class="d-flex align-items-center gap-2 mb-2 pb-2 border-bottom border-light border-opacity-10">
                        <div class="avatar avatar-user">@Model.CustomerName.Substring(0, Math.Min(2, Model.CustomerName.Length)).ToUpper()</div>
                        <span class="fw-bold text-slate-800 small">@Model.CustomerName (Müşteri)</span>
                    </div>
                    <div style="white-space: pre-wrap;">@Model.Description</div>
                    <div class="bubble-meta">
                        <span>🕒 @Model.CreatedDate.ToString("HH:mm")</span>
                    </div>
                </div>

                <!-- Admin Response Bubble (Right) -->
                @if (!string.IsNullOrEmpty(Model.SupportReply))
                {
                    <div class="bubble bubble-right">
                        <div class="d-flex align-items-center gap-2 mb-2 pb-2 border-bottom border-light border-opacity-10">
                            <div class="avatar avatar-agent">@((Model.AssignedAgent ?? "A").Substring(0, Math.Min(2, (Model.AssignedAgent ?? "A").Length)).ToUpper())</div>
                            <span class="fw-bold small text-white">@Model.AssignedAgent (Destek Elemanı)</span>
                        </div>
                        <div style="white-space: pre-wrap;">@Model.SupportReply</div>
                        <div class="bubble-meta">
                            <span>✔ İletildi</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <span class="fs-4 d-block mb-1">💬</span> Henüz bir yanıt verilmemiş.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Admin Reply Form -->
    @if (User.IsInRole("Admin"))
    {
        <div class="card chat-card">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0">Destek Talebini Yanıtla</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Details" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label for="supportReply" class="form-label fw-bold text-secondary">Yanıtınız</label>
                        <textarea name="supportReply" id="supportReply" rows="5" class="form-control form-control-custom" placeholder="Sorunun çözümünü veya detaylı cevabınızı yazın..." required>@Model.SupportReply</textarea>
                    </div>

                    <div class="row align-items-center g-3">
                        <div class="col-md-6 col-lg-4">
                            <label for="status" class="form-label fw-bold text-secondary">Bilet Durumu Güncelle</label>
                            <select name="status" id="status" class="form-select form-control-custom" style="cursor: pointer;">
                                <option value="1" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Acik)">Açık</option>
                                <option value="2" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Cozuldu)">Çözüldü</option>
                                <option value="3" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Kapandi)">Kapandı</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6 col-lg-8 text-md-end pt-md-4">
                            <button type="submit" class="btn btn-custom btn-custom-primary shadow-sm">
                                📩 Yanıtı Kaydet ve Bildir
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
