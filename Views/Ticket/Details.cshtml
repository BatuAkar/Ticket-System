@model TicketSistemi.Models.Ticket

@{
    ViewData["Title"] = "Destek Talebi Detayı";
}

<style>
    .chat-card {
        border-radius: 20px;
        background: var(--card-bg);
        border: var(--card-border);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }
    
    .chat-header {
        border-bottom: 1px solid var(--footer-border);
        background: rgba(99, 102, 241, 0.03);
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }

    .chat-body {
        background-color: var(--bg-color);
        border-radius: 12px;
        padding: 24px;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* Chat bubble base */
    .bubble {
        max-width: 75%;
        padding: 16px 20px;
        border-radius: 20px;
        position: relative;
        line-height: 1.5;
        font-size: 0.95rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
        animation: fadeIn 0.3s ease;
    }

    /* Left aligned bubble (Customer / User) */
    .bubble-left {
        align-self: flex-start;
        background-color: var(--card-bg);
        color: var(--text-color);
        border-top-left-radius: 4px;
        border: 1px solid var(--footer-border);
    }

    /* Right aligned bubble (Admin / Agent) */
    .bubble-right {
        align-self: flex-end;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: #ffffff;
        border-top-right-radius: 4px;
    }

    .bubble-meta {
        font-size: 0.75rem;
        margin-top: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .bubble-left .bubble-meta {
        color: #64748b;
    }

    .bubble-right .bubble-meta {
        color: rgba(255, 255, 255, 0.75);
    }

    .avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .avatar-user {
        background-color: #e0e7ff;
        color: #4f46e5;
    }

    .avatar-agent {
        background-color: #fef3c7;
        color: #d97706;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Timeline styles */
    .timeline {
        position: relative;
        padding-left: 20px;
        list-style: none;
        margin: 0;
    }
    
    .timeline::before {
        content: '';
        position: absolute;
        left: 5px;
        top: 5px;
        bottom: 5px;
        width: 2px;
        background-color: var(--footer-border);
    }
    
    .timeline-item {
        position: relative;
        margin-bottom: 25px;
        padding-left: 15px;
    }
    
    .timeline-item::before {
        content: '';
        position: absolute;
        left: -19px;
        top: 6px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #cbd5e1;
        border: 2px solid var(--card-bg);
    }

    .timeline-item.completed::before {
        background-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15);
    }
    
    .timeline-item.active::before {
        background-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .timeline-item:last-child {
        margin-bottom: 0;
    }
    
    .timeline-title {
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 2px;
    }
    
    .timeline-date {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 4px;
    }
    
    .timeline-desc {
        font-size: 0.8rem;
        color: var(--text-color);
        opacity: 0.8;
    }
</style>

<div class="container py-3">
    <!-- Back to Index Button -->
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-custom rounded-pill d-inline-flex align-items-center gap-2">
            ⬅️ Panele Geri Dön
        </a>
    </div>

    <div class="row g-4">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0 mb-4" role="alert">
                    <div class="d-flex align-items-center">
                        <span class="fs-4 me-2">⚠️</span>
                        <div><strong>Hata!</strong> @TempData["ErrorMessage"]</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        <!-- Left Column: Chat Conversation -->
        <div class="col-lg-8">
            <!-- Ticket Detail Header Info Card -->
            <div class="card chat-card mb-4">
                <div class="chat-header p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                            <span class="badge bg-primary rounded-pill">Talep #@Model.Id</span>
                            @if (Model.Status == TicketSistemi.Models.TicketStatus.Acik)
                            {
                                <span class="badge rounded-pill badge-acik px-3 py-1.5">Açık</span>
                            }
                            else if (Model.Status == TicketSistemi.Models.TicketStatus.Cozuldu)
                            {
                                <span class="badge rounded-pill badge-cozuldu px-3 py-1.5">Çözüldü</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill badge-kapandi px-3 py-1.5">Kapandı</span>
                            }
                            <span class="badge bg-info text-dark rounded-pill px-3 py-1.5">📂 @TicketSistemi.Models.EnumHelper.GetCategoryName(Model.Category)</span>
                            @if (Model.Priority == TicketSistemi.Models.TicketPriority.Yuksek)
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-1.5">🔥 Yüksek Öncelik</span>
                            }
                            else if (Model.Priority == TicketSistemi.Models.TicketPriority.Orta)
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-1.5">⚡ Orta Öncelik</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill px-3 py-1.5">❄️ Düşük Öncelik</span>
                            }
                        </div>
                        <h3 class="fw-bold mb-1 mt-2">@Model.Title</h3>
                        <p class="text-secondary mb-0 small">
                            👤 Müşteri: <strong>@Model.CustomerName</strong> | 📅 Tarih: @Model.CreatedDate.ToString("dd MMMM yyyy HH:mm")
                        </p>
                    </div>
                    
                    <div class="text-md-end">
                        <span class="text-secondary d-block small mb-1">Üstlenen Temsilci</span>
                        @if (!string.IsNullOrEmpty(Model.AssignedAgent))
                        {
                            <span class="badge fw-semibold px-3 py-2 border rounded-pill" style="color: #4338ca; background-color: #e0e7ff; border: 1px solid #c7d2fe; font-size: 0.9rem;">
                                👤 @Model.AssignedAgent
                            </span>
                        }
                        else
                        {
                            <span class="text-muted small">Henüz Atanmadı</span>
                        }
                    </div>
                </div>

                <!-- Chat Conversation Body -->
                <div class="card-body p-4">
                    <div class="chat-body" id="chatBody" style="max-height: 480px; overflow-y: auto; padding-right: 8px;">
                        @if (Model.Messages != null && Model.Messages.Any())
                        {
                            @foreach (var msg in Model.Messages)
                            {
                                var isMsgAdmin = string.Equals(msg.Role, "Admin", StringComparison.OrdinalIgnoreCase);
                                <div class="bubble @(isMsgAdmin ? "bubble-right" : "bubble-left") mb-3">
                                    <div class="d-flex align-items-center gap-2 mb-2 pb-1 border-bottom border-light border-opacity-10">
                                        <div class="avatar @(isMsgAdmin ? "avatar-agent" : "avatar-user")">
                                            @((msg.Sender ?? "U").Substring(0, Math.Min(2, (msg.Sender ?? "U").Length)).ToUpper())
                                        </div>
                                        <span class="fw-bold small @(isMsgAdmin ? "text-white" : "")">
                                            @msg.Sender @(isMsgAdmin ? "(Destek Temsilcisi)" : "(Müşteri)")
                                        </span>
                                    </div>
                                    <div style="word-break: break-word; line-height: 1.6;">@Html.Raw(msg.Message)</div>
                                    
                                    @if (!string.IsNullOrEmpty(msg.AttachmentPath))
                                    {
                                        <div class="mt-3 p-2 rounded border bg-light bg-opacity-10 d-flex flex-column gap-2" style="max-width: 320px;">
                                            @{
                                                var ext = System.IO.Path.GetExtension(msg.AttachmentPath).ToLowerInvariant();
                                                var isImage = ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" || ext == ".webp";
                                            }
                                            @if (isImage)
                                            {
                                                <a href="@msg.AttachmentPath" target="_blank" title="Görseli yeni sekmede aç">
                                                    <img src="@msg.AttachmentPath" alt="@msg.AttachmentFileName" class="img-fluid rounded border shadow-sm" style="max-height: 200px; object-fit: contain;" />
                                                </a>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="fs-4">📄</span>
                                                    <div class="overflow-hidden" style="max-width: 250px;">
                                                        <span class="d-block text-truncate fw-semibold small @(isMsgAdmin ? "text-white" : "")">@msg.AttachmentFileName</span>
                                                        <a href="@msg.AttachmentPath" download class="btn btn-sm btn-light border py-1 px-2 mt-1" style="font-size: 0.75rem;">
                                                            ⬇️ Dosyayı İndir
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <div class="bubble-meta justify-content-end">
                                        <span>🕒 @msg.SentDate.ToString("dd MMM HH:mm")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- Reply Form -->
            <div class="card chat-card" id="replyForm">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">@(User.IsInRole("Admin") ? "Destek Talebini Yanıtla" : "Destek Ekibine Yazın")</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Details" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <!-- Quill Rich Text Editor -->
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Mesajınız</label>
                            <input type="hidden" name="message" id="messageInput" />
                            <div id="editor-container" style="height: 180px; border-bottom-left-radius: 10px; border-bottom-right-radius: 10px; background-color: var(--input-bg); color: var(--input-color);"></div>
                        </div>

                        <!-- Attachment Input -->
                        <div class="mb-3">
                            <label for="attachment" class="form-label fw-bold text-secondary">Dosya Eki (Opsiyonel)</label>
                            <input type="file" name="attachment" id="attachment" class="form-control form-control-custom" />
                            <div class="form-text small text-muted">Desteklenen formatlar: Resim (PNG, JPG, GIF), PDF, TXT, ZIP vb. (Maks 10MB)</div>
                        </div>

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="row g-3 mb-3">
                                <div class="col-md-6">
                                    <label for="category" class="form-label fw-bold text-secondary">Kategori Güncelle</label>
                                    <select name="category" id="category" class="form-select form-control-custom" style="cursor: pointer;">
                                        @foreach (var cat in Enum.GetValues<TicketSistemi.Models.TicketCategory>())
                                        {
                                            <!option value="@((int)cat)" @(Model.Category == cat ? "selected" : "")>@TicketSistemi.Models.EnumHelper.GetCategoryName(cat)</!option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="priority" class="form-label fw-bold text-secondary">Öncelik Güncelle</label>
                                    <select name="priority" id="priority" class="form-select form-control-custom" style="cursor: pointer;">
                                        @foreach (var pri in Enum.GetValues<TicketSistemi.Models.TicketPriority>())
                                        {
                                            <!option value="@((int)pri)" @(Model.Priority == pri ? "selected" : "")>@TicketSistemi.Models.EnumHelper.GetPriorityName(pri)</!option>
                                        }
                                    </select>
                                </div>
                            </div>
                        }

                        <div class="row align-items-center g-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="col-md-6 col-lg-5">
                                    <label for="status" class="form-label fw-bold text-secondary">Bilet Durumu Güncelle</label>
                                    <select name="status" id="status" class="form-select form-control-custom" style="cursor: pointer;">
                                        <option value="1" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Acik)">Açık</option>
                                        <option value="2" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Cozuldu)">Çözüldü</option>
                                        <option value="3" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Kapandi)">Kapandı</option>
                                    </select>
                                </div>
                                <div class="col-md-6 col-lg-7 text-md-end pt-md-4">
                                    <button type="submit" class="btn btn-custom btn-custom-primary shadow-sm">
                                        📩 Yanıtı Gönder ve Güncelle
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-6 col-lg-5">
                                    <label for="status" class="form-label fw-bold text-secondary">Bilet Durumu</label>
                                    <select name="status" id="status" class="form-select form-control-custom" style="cursor: pointer;">
                                        <option value="1" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Acik)">Açık (İşlem Bekliyor)</option>
                                        <option value="3" selected="@(Model.Status == TicketSistemi.Models.TicketStatus.Kapandi)">Kapandı (Sorunum Çözüldü)</option>
                                    </select>
                                </div>
                                <div class="col-md-6 col-lg-7 text-md-end pt-md-4">
                                    <button type="submit" class="btn btn-custom btn-custom-primary shadow-sm">
                                        📩 Mesajı Gönder
                                    </button>
                                </div>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Timeline & Meta Info -->
        <div class="col-lg-4">
            <div class="card chat-card mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">📌 Talep Geçmişi</h5>
                </div>
                <div class="card-body p-4">
                    <ul class="timeline">
                        <!-- Step 1: Talep Oluşturuldu -->
                        <li class="timeline-item completed">
                            <div class="timeline-title">Talep Oluşturuldu</div>
                            <div class="timeline-date">📅 @Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</div>
                            <div class="timeline-desc">Sorun kaydı @Model.CustomerName tarafından sisteme iletildi.</div>
                        </li>

                        <!-- Step 2: Temsilci Atandı -->
                        @if (!string.IsNullOrEmpty(Model.AssignedAgent))
                        {
                            <li class="timeline-item completed">
                                <div class="timeline-title">Temsilci Atandı</div>
                                <div class="timeline-desc">Müşteri temsilcisi <strong>@Model.AssignedAgent</strong> bu talebi üstlendi.</div>
                            </li>
                        }
                        else
                        {
                            <li class="timeline-item active">
                                <div class="timeline-title">Atama Bekleniyor</div>
                                <div class="timeline-desc">Bir destek elemanının biletinizi üstlenmesi bekleniyor.</div>
                            </li>
                        }

                        <!-- Step 3: Destek Yanıtı -->
                        @if (Model.Messages != null && Model.Messages.Any(m => string.Equals(m.Role, "Admin", StringComparison.OrdinalIgnoreCase)))
                        {
                            <li class="timeline-item completed">
                                <div class="timeline-title">Yanıt İletildi</div>
                                <div class="timeline-desc">Destek temsilcisi çözüm detaylarını içeren bir yanıt bıraktı.</div>
                            </li>
                        }
                        else if (!string.IsNullOrEmpty(Model.AssignedAgent))
                        {
                            <li class="timeline-item active">
                                <div class="timeline-title">İnceleme Aşamasında</div>
                                <div class="timeline-desc">Temsilci şu anda biletinizi inceliyor.</div>
                            </li>
                        }

                        <!-- Step 4: Son Durum -->
                        @if (Model.Status == TicketSistemi.Models.TicketStatus.Cozuldu)
                        {
                            <li class="timeline-item completed">
                                <div class="timeline-title text-success">✅ Çözüldü</div>
                                <div class="timeline-desc">Bu destek talebi başarıyla çözüldü olarak işaretlendi.</div>
                            </li>
                        }
                        else if (Model.Status == TicketSistemi.Models.TicketStatus.Kapandi)
                        {
                            <li class="timeline-item completed">
                                <div class="timeline-title text-secondary">🔒 Kapandı</div>
                                <div class="timeline-desc">Talep arşive alındı ve kapatıldı.</div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <style>
        .ql-toolbar.ql-snow {
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
            background-color: var(--input-bg);
            border-color: var(--input-border);
        }
        .ql-container.ql-snow {
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 10px;
            border-color: var(--input-border);
        }
    </style>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Auto scroll chat body to the bottom
            const chatBody = document.getElementById("chatBody");
            if (chatBody) {
                chatBody.scrollTop = chatBody.scrollHeight;
            }

            // Quill initialization
            var quill = new Quill('#editor-container', {
                theme: 'snow',
                placeholder: 'Cevabınızı buraya yazabilirsiniz...',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                        ['code-block', 'blockquote'],
                        ['clean']
                    ]
                }
            });

            const statusSelect = document.getElementById("status");
            const categorySelect = document.getElementById("category");
            const prioritySelect = document.getElementById("priority");

            const initialStatus = statusSelect ? statusSelect.value : "";
            const initialCategory = categorySelect ? categorySelect.value : "";
            const initialPriority = prioritySelect ? prioritySelect.value : "";

            var form = document.querySelector('#replyForm form');
            form.onsubmit = function () {
                var messageInput = document.querySelector('#messageInput');
                var htmlContent = quill.root.innerHTML;
                
                var fileInput = document.querySelector('#attachment');
                var hasAttachment = fileInput && fileInput.files && fileInput.files.length > 0;
                
                const currentStatus = statusSelect ? statusSelect.value : "";
                const currentCategory = categorySelect ? categorySelect.value : "";
                const currentPriority = prioritySelect ? prioritySelect.value : "";
                
                const isMetadataChanged = (currentStatus !== initialStatus) || 
                                          (currentCategory !== initialCategory) || 
                                          (currentPriority !== initialPriority);

                if (quill.getText().trim().length === 0 && !hasAttachment) {
                    messageInput.value = '';
                    if (!isMetadataChanged) {
                        alert('Lütfen bir mesaj yazın, bir dosya ekleyin ya da bilet bilgilerini güncelleyin.');
                        return false;
                    }
                } else {
                    messageInput.value = htmlContent;
                }
            };
        });
    </script>
}
