@model TicketSistemi.Models.Ticket

@{
    ViewData["Title"] = "Yeni Talep Oluştur";
}

<div class="container mt-4">
    <h2>Yeni Destek Talebi Oluştur</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">
                
                <div class="mb-3">
                    <label asp-for="CustomerName" class="form-label">Adınız Soyadınız</label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Örn: John Doe" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Konu Başlığı</label>
                    <input asp-for="Title" class="form-control" placeholder="Kısaca sorununuz nedir?" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Detaylı Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Lütfen karşılaştığınız sorunu detaylıca anlatın..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Talebi Gönder</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Geri Dön</a>
            </form>
        </div>
    </div>
</div>