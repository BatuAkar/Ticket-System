@model TicketSistemi.Models.Ticket

@{
    ViewData["Title"] = "Yeni Destek Talebi Aç";
}

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card card-custom border-0 shadow-sm overflow-hidden mb-4">
            
            <!-- Card Header -->
            <div class="card-header text-white p-4" style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);">
                <div class="d-flex align-items-center">
                    <span class="fs-2 me-3">🚀</span>
                    <div>
                        <h4 class="mb-0 fw-bold">Yeni Destek Talebi</h4>
                        <p class="text-white-50 small mb-0">Sorununuzu bize bildirin, ekibimiz en kısa sürede ilgilenecektir.</p>
                    </div>
                </div>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    
                    <!-- Customer Information (Readonly) -->
                    <div class="mb-4">
                        <label class="form-label text-secondary small fw-bold tracking-wider">TALEP SAHİBİ</label>
                        <div class="d-flex align-items-center bg-light p-3 rounded-3 border">
                            <span class="fs-4 me-2">👤</span>
                            <span class="fw-bold text-dark">@User.Identity?.Name</span>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label asp-for="Category" class="form-label text-slate-700 fw-semibold">Kategori</label>
                            <select asp-for="Category" class="form-select form-control-custom">
                                @foreach (var cat in Enum.GetValues<TicketSistemi.Models.TicketCategory>())
                                {
                                    <option value="@((int)cat)">@TicketSistemi.Models.EnumHelper.GetCategoryName(cat)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Priority" class="form-label text-slate-700 fw-semibold">Öncelik Seviyesi</label>
                            <select asp-for="Priority" class="form-select form-control-custom">
                                @foreach (var pri in Enum.GetValues<TicketSistemi.Models.TicketPriority>())
                                {
                                    <option value="@((int)pri)">@TicketSistemi.Models.EnumHelper.GetPriorityName(pri)</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label text-slate-700 fw-semibold">Konu Başlığı</label>
                        <input asp-for="Title" class="form-control form-control-custom" placeholder="Sorununuzu kısaca özetleyin (örn: Sunucu Bağlantı Hatası)" />
                        <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Description (Quill Rich Text) -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label text-slate-700 fw-semibold">Detaylı Açıklama</label>
                        <input type="hidden" asp-for="Description" id="descriptionInput" />
                        <div id="editor-container" style="height: 250px; border-bottom-left-radius: 10px; border-bottom-right-radius: 10px; background-color: var(--input-bg); color: var(--input-color);"></div>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Attachment -->
                    <div class="mb-4">
                        <label class="form-label text-slate-700 fw-semibold">Dosya Eki (Opsiyonel)</label>
                        <input type="file" name="attachment" class="form-control form-control-custom" />
                        <div class="form-text small text-muted">Desteklenen formatlar: Resim (PNG, JPG, GIF), PDF, TXT, ZIP vb. (Maks 10MB)</div>
                        <span class="text-danger small mt-1 d-block">@Html.ValidationMessage("attachment")</span>
                    </div>

                    <!-- Form Actions -->
                    <div class="d-flex align-items-center justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light btn-custom text-secondary border px-4">
                            Geri Dön
                        </a>
                        <button type="submit" class="btn btn-custom btn-custom-primary px-4 shadow-sm">
                            Talebi Gönder
                        </button>
                    </div>
                </form>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <style>
        .ql-toolbar.ql-snow {
            border-top-left-radius: 10px;
            border-top-right-radius: 10px;
            background-color: var(--input-bg);
            border-color: var(--input-border);
        }
        .ql-container.ql-snow {
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 10px;
            border-color: var(--input-border);
        }
    </style>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var quill = new Quill('#editor-container', {
                theme: 'snow',
                placeholder: 'Yaşadığınız problemi, varsa hata kodlarını ve adımları detaylıca açıklayınız...',
                modules: {
                    toolbar: [
                        [{ 'header': [1, 2, 3, false] }],
                        ['bold', 'italic', 'underline', 'strike'],
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                        ['code-block', 'blockquote'],
                        ['clean']
                    ]
                }
            });

            // Load existing content if validation failed
            var initialContent = document.querySelector('#descriptionInput').value;
            if (initialContent) {
                quill.root.innerHTML = initialContent;
            }

            var form = document.querySelector('form');
            form.onsubmit = function () {
                var descriptionInput = document.querySelector('#descriptionInput');
                var htmlContent = quill.root.innerHTML;
                
                // If the user entered nothing, set input value to empty string so validation triggers
                if (quill.getText().trim().length === 0) {
                    descriptionInput.value = '';
                } else {
                    descriptionInput.value = htmlContent;
                }
            };
        });
    </script>
}