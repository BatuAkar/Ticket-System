@model IEnumerable<TicketSistemi.Models.Ticket>

@{
    ViewData["Title"] = "Destek Paneli";
    
    var toplamTicket = ViewBag.TotalCount;
    var acikTicket = ViewBag.OpenCount;
    var cozulunTicket = ViewBag.SolvedCount;
    var kapandiTicket = ViewBag.ClosedCount;
}

<style>
    /* Gradient stats card colors */
    .bg-gradient-indigo { 
        background: linear-gradient(135deg, #6366f1, #4338ca) !important; 
    }
    .bg-gradient-amber { 
        background: linear-gradient(135deg, #f59e0b, #d97706) !important; 
    }
    .bg-gradient-emerald { 
        background: linear-gradient(135deg, #10b981, #059669) !important; 
    }
    .bg-gradient-slate { 
        background: linear-gradient(135deg, #64748b, #475569) !important; 
    }
    
    .stat-card-custom {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: none !important;
        border-radius: 16px;
    }
    .stat-card-custom:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12) !important;
    }

    .table-container {
        background: var(--card-bg);
        border-radius: 16px;
        border: var(--card-border);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .custom-table th {
        background-color: var(--bg-color) !important;
        color: var(--text-color);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid var(--footer-border);
    }

    .custom-table tr {
        transition: background-color 0.2s ease;
        background-color: var(--card-bg);
        color: var(--text-color);
    }

    .custom-table tr:hover {
        background-color: var(--bg-color) !important;
    }
</style>

<div class="container">
    <!-- Header Section -->
    <div class="row align-items-center mb-4 pb-3 border-bottom g-3">
        <div class="col-md-8">
            <h2 class="fw-bold mb-1">Destek Talepleri Yönetim Paneli</h2>
            <p class="text-secondary mb-0">Sistem veritabanındaki anlık bilet durumları ve canlı analizler.</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a asp-action="Create" class="btn btn-custom btn-custom-primary shadow-sm text-decoration-none">
                🚀 Yeni Destek Talebi Aç
            </a>
        </div>
    </div>

    <!-- Analytics Stats & Chart Section -->
    <div class="row g-4 mb-5">
        <!-- Cards Grid (Left side) -->
        <div class="col-lg-8">
            <div class="row g-4">
                <div class="col-sm-6">
                    <a href="?status=" class="text-decoration-none">
                        <div class="card stat-card-custom shadow-sm bg-gradient-indigo text-white">
                            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 text-uppercase fw-bold small mb-1">Toplam Talep</h6>
                                    <h2 class="display-6 fw-bold mb-0">@toplamTicket</h2>
                                </div>
                                <div class="fs-1 opacity-50">📊</div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <a href="?status=1" class="text-decoration-none">
                        <div class="card stat-card-custom shadow-sm bg-gradient-amber text-white">
                            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 text-uppercase fw-bold small mb-1">Bekleyen (Açık)</h6>
                                    <h2 class="display-6 fw-bold mb-0">@acikTicket</h2>
                                </div>
                                <div class="fs-1 opacity-50">⏳</div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <a href="?status=2" class="text-decoration-none">
                        <div class="card stat-card-custom shadow-sm bg-gradient-emerald text-white">
                            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 text-uppercase fw-bold small mb-1">Çözülen Talepler</h6>
                                    <h2 class="display-6 fw-bold mb-0">@cozulunTicket</h2>
                                </div>
                                <div class="fs-1 opacity-50">✅</div>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-sm-6">
                    <a href="?status=3" class="text-decoration-none">
                        <div class="card stat-card-custom shadow-sm bg-gradient-slate text-white">
                            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="text-white-50 text-uppercase fw-bold small mb-1">Kapatılan Talepler</h6>
                                    <h2 class="display-6 fw-bold mb-0">@kapandiTicket</h2>
                                </div>
                                <div class="fs-1 opacity-50">🔒</div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <!-- Donut Chart Card (Right side) -->
        <div class="col-lg-4">
            <div class="card card-custom shadow-sm h-100">
                <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center text-center">
                    <h6 class="text-uppercase fw-bold small mb-3 text-secondary w-100">Talep Durum Dağılımı</h6>
                    <div style="position: relative; height: 180px; width: 100%;">
                        <canvas id="ticketStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tickets List Table -->
    <div class="table-container mb-4">
        <div class="card-header bg-transparent border-0 py-4 px-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <h5 class="mb-0 fw-bold d-flex align-items-center">
                <span class="me-2">📋</span> Bilet Listesi
            </h5>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <!-- Search Input -->
                <div class="position-relative">
                    <input type="text" id="instantSearch" class="form-control form-control-custom" placeholder="🔍 Taleplerde ara..." style="min-width: 240px; border-radius: 10px;" />
                </div>
                <!-- Status Filter Dropdown -->
                <select id="statusFilter" class="form-select form-control-custom" style="min-width: 140px; border-radius: 10px; cursor: pointer;">
                    <option value="">Tümü (Durum)</option>
                    <option value="AÇIK">Açık</option>
                    <option value="ÇÖZÜLDÜ">Çözüldü</option>
                    <option value="KAPANDI">Kapandı</option>
                </select>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table custom-table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">TALEP ID</th>
                        <th class="py-3">KONU BAŞLIĞI</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="py-3">MÜŞTERİ</th>
                        }
                        <th class="py-3">OLUŞTURMA TARİHİ</th>
                        <th class="py-3">ÜSTLENEN</th>
                        <th class="py-3">DURUM</th>
                        <th class="py-3 text-end pe-4">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@(User.IsInRole("Admin") ? 7 : 6)" class="text-center py-5 text-muted">
                                <span class="fs-2 d-block mb-3">🎈</span> Destek talebi bulunmuyor.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold" style="color: #4f46e5;">#@item.Id</td>
                                <td>
                                    <span class="fw-bold d-block">@item.Title</span>
                                    <small class="text-muted d-inline-block text-truncate" style="max-width: 320px;">@item.Description</small>
                                </td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="fw-semibold text-secondary">@item.CustomerName</td>
                                }
                                <td class="text-muted">@item.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.AssignedAgent))
                                    {
                                        <span class="badge fw-semibold px-2.5 py-1.5 border rounded-pill" style="color: #4338ca; background-color: #e0e7ff; border: 1px solid #c7d2fe;">
                                            👤 @item.AssignedAgent
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Atanmadı</span>
                                    }
                                </td>
                                <td class="status-cell">
                                    @if(item.Status == TicketSistemi.Models.TicketStatus.Acik)
                                    {
                                        <span class="badge rounded-pill badge-acik px-3 py-2">Açık</span>
                                    }
                                    else if(item.Status == TicketSistemi.Models.TicketStatus.Cozuldu)
                                    {
                                        <span class="badge rounded-pill badge-cozuldu px-3 py-2">Çözüldü</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill badge-kapandi px-3 py-2">Kapandı</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex gap-1">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            @if (string.IsNullOrEmpty(item.AssignedAgent))
                                            {
                                                <form asp-action="Claim" asp-route-id="@item.Id" method="post" class="m-0">
                                                    <button type="submit" class="btn btn-sm btn-success px-3 fw-bold rounded-pill shadow-sm">
                                                        🙋‍♂️ Üstlen
                                                    </button>
                                                </form>
                                            }
                                            <a asp-action="Reply" asp-route-id="@item.Id" class="btn btn-sm btn-primary px-3 fw-bold rounded-pill shadow-sm">
                                                🛠️ Cevapla
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Bu destek talebini silmek istediğinize emin misiniz?');">
                                                <button type="submit" class="btn btn-sm btn-danger px-3 fw-bold rounded-pill shadow-sm">
                                                    🗑️ Sil
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white px-3 fw-bold rounded-pill shadow-sm">
                                                🔍 Detay
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Chart.js Donut Chart
            const ctx = document.getElementById('ticketStatusChart').getContext('2d');
            const openCount = @acikTicket;
            const solvedCount = @cozulunTicket;
            const closedCount = @kapandiTicket;

            // Total is 0 safety check
            const total = openCount + solvedCount + closedCount;

            const chart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Açık', 'Çözüldü', 'Kapandı'],
                    datasets: [{
                        data: total === 0 ? [1, 0, 0] : [openCount, solvedCount, closedCount],
                        backgroundColor: total === 0 ? ['#e2e8f0'] : [
                            '#f59e0b', // Amber
                            '#10b981', // Emerald
                            '#64748b'  // Slate
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#f8fafc' : '#475569',
                                font: {
                                    family: 'Outfit',
                                    size: 11
                                },
                                padding: 15,
                                boxWidth: 12
                            }
                        }
                    },
                    cutout: '70%'
                }
            });

            // Re-render chart text color on theme change
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === "data-bs-theme") {
                        const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                        chart.options.plugins.legend.labels.color = isDark ? '#f8fafc' : '#475569';
                        chart.update();
                    }
                });
            });
            observer.observe(document.documentElement, { attributes: true });

            // Instant Search & Client-side Filtering
            const searchInput = document.getElementById("instantSearch");
            const statusSelect = document.getElementById("statusFilter");
            const tableRows = document.querySelectorAll(".custom-table tbody tr");

            function filterTable() {
                const searchText = searchInput.value.toLowerCase().trim();
                const selectedStatus = statusSelect.value;

                tableRows.forEach(row => {
                    // Check if it's the "No tickets" empty row
                    if (row.querySelector("td[colspan]")) {
                        return;
                    }

                    // Extract text content
                    const idText = row.querySelector("td:first-child").textContent.toLowerCase();
                    const titleAndDescText = row.querySelector("td:nth-child(2)").textContent.toLowerCase();
                    
                    let customerText = "";
                    const customerTd = row.querySelector("td.fw-semibold.text-secondary") || row.querySelector("td:nth-child(3)");
                    if (customerTd && @(User.IsInRole("Admin") ? "true" : "false")) {
                        customerText = customerTd.textContent.toLowerCase();
                    }

                    // Locate status text
                    let statusText = "";
                    const statusBadge = row.querySelector(".status-cell .badge");
                    if (statusBadge) {
                        statusText = statusBadge.textContent.trim().toUpperCase(); // "AÇIK", "ÇÖZÜLDÜ", "KAPANDI"
                    }

                    const matchesSearch = idText.includes(searchText) || 
                                          titleAndDescText.includes(searchText) || 
                                          customerText.includes(searchText);

                    let matchesStatus = true;
                    if (selectedStatus) {
                        matchesStatus = statusText === selectedStatus;
                    }

                    if (matchesSearch && matchesStatus) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            }

            if (searchInput) searchInput.addEventListener("input", filterTable);
            if (statusSelect) statusSelect.addEventListener("change", filterTable);

            // If page loaded with a status filter from backend, set the select option and apply filter
            const urlParams = new URLSearchParams(window.location.search);
            const statusParam = urlParams.get('status');
            if (statusParam === '1') {
                statusSelect.value = 'AÇIK';
            } else if (statusParam === '2') {
                statusSelect.value = 'ÇÖZÜLDÜ';
            } else if (statusParam === '3') {
                statusSelect.value = 'KAPANDI';
            }
            filterTable();
        });
    </script>
}