@{
    Layout = null;
    ViewData["Title"] = "Sistem Girişi";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
        }

        .login-card {
            border: none;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            background: #ffffff;
            transition: all 0.3s ease;
        }

        .login-header {
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
            padding: 45px 20px;
            color: white;
            text-align: center;
            border-bottom: 2px solid #334155;
        }

        .login-icon-wrapper {
            width: 76px;
            height: 76px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 38px;
            border: 2px solid rgba(255, 255, 255, 0.15);
        }

        .form-control-custom {
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }

        .form-control-custom:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
            outline: none;
        }

        .btn-login {
            background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
            border: none;
            border-radius: 12px;
            padding: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.25s ease;
            color: white;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
            background: linear-gradient(135deg, #4338ca 0%, #3730a3 100%);
            color: white;
        }

        .info-box {
            background: #f8fafc;
            border-left: 4px solid #6366f1;
            border-radius: 10px;
            border-top: 1px solid #e2e8f0;
            border-right: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
            <div class="col-md-5 col-lg-4">
                <div class="card login-card">
                    <div class="login-header">
                        <div class="login-icon-wrapper">
                            🔐
                        </div>
                        <h4 class="fw-bold mb-1">Destek Portalı</h4>
                        <p class="text-white-50 small mb-0">Erişim sağlamak için bilgilerinizi girin</p>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger border-0 small shadow-sm mb-4" style="border-radius: 10px;">
                                <i class="me-2">🚫</i> @ViewBag.ErrorMessage
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">KULLANICI ADI</label>
                                <input type="text" name="username" class="form-control form-control-custom" required placeholder="admin veya user" autocomplete="off" />
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label text-secondary small fw-bold">ŞİFRE</label>
                                <input type="password" name="password" class="form-control form-control-custom" required placeholder="••••••" />
                            </div>

                            <button type="submit" class="btn btn-login w-100 shadow-sm d-flex align-items-center justify-content-center gap-2">
                                Giriş Yap <span>→</span>
                            </button>
                        </form>

                        <div class="info-box p-3 mt-4">
                            <div class="d-flex align-items-center mb-1">
                                <span class="me-2">💡</span>
                                <span class="small fw-bold text-dark">Demo Hesap Bilgileri:</span>
                            </div>
                            <div class="ps-4">
                                <p class="mb-0 x-small text-muted" style="font-size: 0.75rem; line-height: 1.5;">
                                    <strong>Yönetici (Admin):</strong> admin / 123 <br>
                                    <strong>Müşteri (User):</strong> user / 123
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="text-center mt-4 text-white-50 small">
                    &copy; 2026 Teknik Destek Takip Sistemi
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>