<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Ticket" asp-action="Index">Destek Paneli</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Ticket" asp-action="Index">Talepleri Listele</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Ticket" asp-action="Create">Yeni Talep Aç</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav">
                        @if (Context.Request.Cookies["UserRole"] != null)
                        {
                            // Eğer kullanıcı giriş yaptıysa rolünü ve çıkış butonunu göster
                            <li class="nav-item">
                                <span class="nav-link text-warning">
                                    Rol: <strong>@Context.Request.Cookies["UserRole"]</strong>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm mt-1" asp-controller="Account" asp-action="Logout">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            // Giriş yapmadıysa Giriş Yap butonunu göster
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm mt-1" asp-controller="Account" asp-action="Login">Sistem Girişi</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center mt-5 pt-3">
        <div class="container">
            &copy; 2026 - Web Programlama Dersi 2. Projesi - Ticket Sistemi
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>