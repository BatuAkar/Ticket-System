<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketSistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
        }

        /* Modern Navbar */
        .navbar-custom {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.15);
            border-bottom: 2px solid #334155;
            padding: 16px 0;
        }

        .navbar-brand-custom {
            font-weight: 800;
            letter-spacing: 0.5px;
            font-size: 1.35rem;
            color: #ffffff !important;
            display: flex;
            align-items: center;
        }

        .nav-link-custom {
            font-weight: 500;
            color: rgba(255, 255, 255, 0.85) !important;
            border-radius: 8px;
            padding: 8px 16px !important;
            margin-right: 8px;
            transition: all 0.25s ease;
        }

        .nav-link-custom:hover {
            color: #ffffff !important;
            background-color: rgba(255, 255, 255, 0.08);
        }

        /* Modern Card system */
        .card-custom {
            background: #ffffff;
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px -1px rgba(0, 0, 0, 0.02);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 20px -5px rgba(0, 0, 0, 0.08), 0 8px 8px -5px rgba(0, 0, 0, 0.04);
        }

        /* Inputs and Forms */
        .form-control-custom {
            border-radius: 10px;
            padding: 11px 15px;
            border: 1px solid #cbd5e1;
            background-color: #ffffff;
            transition: all 0.2s ease;
        }

        .form-control-custom:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
            outline: none;
        }

        /* Badge status colors */
        .badge-acik {
            background-color: #fef3c7;
            color: #d97706;
            font-weight: 700;
        }
        
        .badge-cozuldu {
            background-color: #d1fae5;
            color: #059669;
            font-weight: 700;
        }
        
        .badge-kapandi {
            background-color: #e2e8f0;
            color: #475569;
            font-weight: 700;
        }

        /* Modern Buttons */
        .btn-custom {
            border-radius: 10px;
            font-weight: 600;
            padding: 10px 20px;
            transition: all 0.25s ease;
        }

        .btn-custom-primary {
            background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
            color: white;
            border: none;
        }

        .btn-custom-primary:hover {
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
            background: linear-gradient(135deg, #4338ca 0%, #3730a3 100%);
            color: white;
        }

        footer {
            background: #ffffff;
            border-top: 1px solid #e2e8f0;
            color: #64748b;
            padding: 24px 0;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom mb-4">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom" asp-controller="Ticket" asp-action="Index">
                    <span class="me-2">🎫</span> Destek Paneli
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                    @if (Context.Request.Cookies["UserRole"] != null)
                    {
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom text-white" asp-controller="Ticket" asp-action="Create">Yeni Talep Aç</a>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav flex-grow-1"></ul>
                    }

                    <ul class="navbar-nav align-items-center">
                        @if (Context.Request.Cookies["UserRole"] != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="btn btn-outline-light dropdown-toggle px-3 py-1.5 rounded-pill fw-semibold d-flex align-items-center gap-2 text-decoration-none" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👤 @Context.Request.Cookies["Username"]
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2 p-2" aria-labelledby="profileDropdown" style="border-radius: 12px; min-width: 200px;">
                                    <li>
                                        <div class="px-3 py-1.5 text-secondary small fw-bold text-uppercase tracking-wider border-bottom mb-1" style="font-size: 0.7rem;">Hesap Bilgileri</div>
                                    </li>
                                    <li>
                                        <span class="dropdown-item-text text-dark fw-semibold d-flex align-items-center gap-2 small">
                                            🛡️ Rol: <span class="badge bg-warning text-dark rounded-pill fw-bold">@Context.Request.Cookies["UserRole"]</span>
                                        </span>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger fw-semibold d-flex align-items-center gap-2 rounded-3 small" asp-controller="Account" asp-action="Logout">
                                            🚪 Çıkış Yap
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center mt-5">
        <div class="container">
            &copy; 2026 - Teknik Destek Takip Portalı - Web Programlama Dersi Projesi
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>